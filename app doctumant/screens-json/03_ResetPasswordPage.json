{
  "screenName": "ResetPasswordPage",
  "route": "/reset-password",
  "purpose": "Set new password after clicking recovery link.",
  "navigation": {
    "from": [
      "Password reset email"
    ],
    "to": [
      "/auth"
    ]
  },
  "appBar": {},
  "layout": {
    "type": "column",
    "children": []
  },
  "components": [
    {
      "id": "newPwd",
      "type": "Input",
      "name": "newPassword"
    },
    {
      "id": "confirmPwd",
      "type": "Input",
      "name": "confirmPassword"
    },
    {
      "id": "submit",
      "type": "Button",
      "text": "Update password",
      "action": "supabase.auth.updateUser({password})"
    }
  ],
  "forms": [
    {
      "name": "reset",
      "fields": [
        "newPassword",
        "confirmPassword"
      ]
    }
  ],
  "buttons": [],
  "lists": [],
  "cards": [],
  "dialogs": [],
  "bottomSheets": [],
  "tabs": [],
  "filters": [],
  "search": {},
  "apiCalls": [
    {
      "name": "auth.updateUser",
      "method": "PUT",
      "endpoint": "auth/v1/user"
    }
  ],
  "stateManagement": [],
  "validation": [
    {
      "field": "newPassword",
      "rule": "min 8"
    },
    {
      "field": "confirmPassword",
      "rule": "must match"
    }
  ],
  "loadingState": {},
  "errorState": {},
  "emptyState": {},
  "successState": {},
  "assets": [],
  "animations": [],
  "responsiveRules": {
    "maxWidth": "448px (max-w-md)",
    "safeArea": "env(safe-area-inset-top/bottom)",
    "mobileFirst": true
  },
  "designTokens": {
    "colors": {
      "primary": "#E6287A",
      "primaryForeground": "#FFFFFF",
      "accent": "#FFB800",
      "background": "#FFFFFF",
      "foreground": "#0F172A",
      "muted": "#F1F5F9",
      "mutedForeground": "#64748B",
      "border": "#E2E8F0",
      "destructive": "#EF4444",
      "gradientHeader": "linear-gradient(135deg,#E6287A,#FF6BAA)"
    },
    "font": "Roboto"
  }
}